TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=

# Optional: change the Gemini model without editing code.
# GEMINI_MODEL=gemini-2.5-flash
# MAX_VOICE_BYTES=14680064

# Optional: enable webhook mode for web-service hosting such as Render.
# Keep these unset when running locally with polling.
# BOT_MODE=webhook
# WEBHOOK_URL=https://your-render-service.onrender.com
# WEBHOOK_PATH=telegram-webhook
# WEBHOOK_SECRET_TOKEN=change-this-random-string

# Optional: persistent memory for Vercel/serverless deployments.
# BOT_MODE=serverless
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
